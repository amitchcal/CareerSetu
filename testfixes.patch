diff --git a/tests/e2e/pages/AuthPage.ts b/tests/e2e/pages/AuthPage.ts
index bf3c326..b7e7070 100644
--- a/tests/e2e/pages/AuthPage.ts
+++ b/tests/e2e/pages/AuthPage.ts
@@ -26,8 +26,40 @@ export class AuthPage {
     await this.page.getByRole('button', { name: 'Create account' }).click()
   }
 
+  /**
+   * Waits for the post-login/signup redirect to /dashboard or /onboarding.
+   * If the app shows a "Login failed" / "Signup failed" toast instead, this
+   * fails immediately with the toast text rather than a bare N-second
+   * timeout — that toast is what a stale/incorrect TEST_USER_EMAIL /
+   * TEST_USER_PASSWORD looks like, and previously surfaced only as an
+   * unexplained `page.waitForURL` timeout.
+   */
   async expectLandedInApp(timeout = 20_000) {
-    await this.page.waitForURL(/\/(dashboard|onboarding)/, { timeout })
+    const failedToast = this.page.getByText(/login failed|signup failed/i).first()
+
+    const landed = this.page.waitForURL(/\/(dashboard|onboarding)/, { timeout })
+      .then(() => 'landed' as const)
+      .catch(() => null)
+    const failed = failedToast.waitFor({ timeout })
+      .then(() => 'failed' as const)
+      .catch(() => null)
+
+    const outcome = await Promise.race([landed, failed])
+
+    if (outcome === 'failed') {
+      const toastText = await failedToast.textContent().catch(() => null)
+      throw new Error(
+        `Login/signup failed instead of redirecting — error toast: "${toastText ?? '(unreadable)'}". ` +
+        `If this is an authenticated-journey test, verify TEST_USER_EMAIL / TEST_USER_PASSWORD point to a ` +
+        `real, existing, confirmed account (accounts can go stale if Supabase users were deleted/reset).`
+      )
+    }
+    if (outcome !== 'landed') {
+      throw new Error(
+        `Timed out after ${timeout}ms waiting to land on /dashboard or /onboarding, and no error toast ` +
+        `appeared either. Current URL: ${this.page.url()}`
+      )
+    }
     await expect(this.page).toHaveURL(/\/(dashboard|onboarding)/)
   }
 }
